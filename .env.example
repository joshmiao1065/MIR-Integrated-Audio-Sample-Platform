# Database (asyncpg driver for the app, plain psycopg2 URL for alembic CLI if needed)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/audio_samples

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=audio-previews

# Freesound API
FREESOUND_API_KEY=your-freesound-api-key
FREESOUND_CLIENT_ID=your-client-id
FREESOUND_CLIENT_SECRET=your-client-secret

# Auth
SECRET_KEY=generate-a-strong-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
